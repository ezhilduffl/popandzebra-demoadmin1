</div>

@section Scripts {
    <script>
        var maxSize     = 3 * 1024 * 1024;
        var allowedExts = new RegExp('\\.(jpg|jpeg|png|gif)$', 'i');

        function previewImage(input) {
            var file  = input.files[0];
            var box   = document.getElementById('imagePreviewBox');
            var errEl = document.getElementById('imageFileError');
            errEl.textContent = '';

            if (!file) return;

            if (!allowedExts.test(file.name)) {
                errEl.textContent = 'Only JPG, PNG, and GIF files are allowed.';
                input.value = '';
                return;
            }
            if (file.size > maxSize) {
                errEl.textContent = 'File size must not exceed 3 MB.';
                input.value = '';
                return;
            }

            var reader = new FileReader();
            reader.onload = function (e) {
                box.innerHTML =
                    '<img src="' + e.target.result + '" ' +
                    'style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />';
            };
            reader.readAsDataURL(file);
        }

        document.getElementById('workEditForm').addEventListener('submit', function (e) {
            var valid = true;
            var order = document.querySelector('select[name="DisplayOrder"]').value;
            if (!order) {
                document.getElementById('orderError').textContent =
                    'Please select a display order.';
                valid = false;
            } else {
                document.getElementById('orderError').textContent = '';
            }
            if (!valid) e.preventDefault();
        });
    </script>
} *@



@model PopZebra.Models.WorkItemViewModel
@{
    ViewData["Title"] = "Work - Edit";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>Edit Work Item
            </div>
            <div class="card-body">

                <form method="post"
                      asp-action="Edit"
                      asp-route-id="@Model.Id"
                      enctype="multipart/form-data"
                      id="workEditForm"
                      novalidate>
                    @Html.AntiForgeryToken()

                    @* <%-- Hidden field to pass replace decision --%> *@
                    <input type="hidden"
                           id="replaceOrderInput"
                           name="replaceOrder"
                           value="false" />

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Enter work item title" />
                        <span asp-validation-for="Title"
                              class="text-danger small"></span>
                    </div>

                    <!-- Link URL -->
                    <div class="mb-4">
                        <label asp-for="LinkUrl" class="form-label">
                            Link URL <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-link-45deg"></i>
                            </span>
                            <input asp-for="LinkUrl"
                                   class="form-control"
                                   placeholder="https://..." />
                        </div>
                        <span asp-validation-for="LinkUrl"
                              class="text-danger small"></span>
                    </div>

                    <!-- Display Order — ALL 10 shown -->
                    <div class="mb-4">
                        <label asp-for="DisplayOrder" class="form-label">
                            Display Order <span class="text-danger">*</span>
                        </label>
                        <select name="DisplayOrder"
                                id="displayOrderSelect"
                                class="form-select">
                            <option value="">-- Select display order --</option>
                            @foreach (var order in Model.AvailableOrders)
                            {
                                if (Model.DisplayOrder == order)
                                {
                                    <option value="@order" selected>
                                        @order (current)
                                    </option>
                                }
                                else
                                {
                                    <option value="@order">@order</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="DisplayOrder"
                              class="text-danger small"></span>
                        <div id="orderError"
                             class="text-danger small mt-1"></div>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-4">
                        <label class="form-label">
                            Image
                            <small class="text-muted fw-normal">
                                (Upload new to replace)
                            </small>
                        </label>
                        @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                        {
                            <div class="mb-2">
                                <img src="@Model.ExistingImagePath"
                                     style="height:120px;object-fit:cover;
                                                border-radius:8px;display:block;"
                                     alt="Current image" />
                                <small class="text-muted">Current image</small>
                            </div>
                        }
                        <div class="img-preview-box"
                             id="imagePreviewBox"
                             onclick="document.getElementById('imageFileInput').click()">
                            <div class="placeholder-text">
                                <i class="bi bi-cloud-upload fs-3 d-block mb-2 text-muted"></i>
                                Click to upload new image<br />
                                <small>JPG, PNG, GIF — max 3MB</small>
                            </div>
                        </div>
                        <input type="file"
                               id="imageFileInput"
                               name="ImageFile"
                               accept=".jpg,.jpeg,.png,.gif"
                               class="d-none"
                               onchange="previewImage(this)" />
                        <div id="imageFileError"
                             class="text-danger small mt-1"></div>
                    </div>

                    <!-- Timestamps -->
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="form-label text-muted small">
