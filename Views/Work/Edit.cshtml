                        <button type="submit" class="btn btn-primary px-4"
                                id="updateBtn">
                            <i class="bi bi-check-circle me-1"></i>Update
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- ── Replace Order Confirmation Popup ──────────────── -->
<div id="replacePopupOverlay"
     style="display:none;position:fixed;inset:0;z-index:1050;
            background:rgba(0,0,0,.45);align-items:center;
            justify-content:center;padding:20px;">
    <div style="background:#fff;border-radius:16px;padding:36px 32px;
                max-width:440px;width:100%;box-shadow:0 20px 50px rgba(0,0,0,.2);
                position:relative;">

        <!-- Warning icon -->
        <div style="width:60px;height:60px;background:#fef3c7;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;
                    margin:0 auto 20px;">
            <i class="bi bi-exclamation-triangle-fill"
               style="font-size:1.6rem;color:#d97706;"></i>
        </div>

        <h5 class="fw-bold text-center mb-2">Order Already Taken</h5>

        <p class="text-muted text-center small mb-4"
           id="popupMessage">
        </p>

        <div class="d-flex gap-2 justify-content-center">

            <!-- Back button — revert to current order -->
            <button type="button"
                    class="btn btn-outline-secondary px-4"
                    id="popupBackBtn"
                    onclick="cancelReplace()">
                <i class="bi bi-arrow-left me-1"></i>Back
            </button>

            <!-- Replace button — swap orders and submit -->
            <button type="button"
                    class="btn btn-warning px-4"
                    id="popupReplaceBtn"
                    onclick="confirmReplace()">
                <i class="bi bi-arrow-left-right me-1"></i>
                Replace &amp; Swap
            </button>

        </div>

        <p class="text-muted text-center mt-3 mb-0"
           style="font-size:.78rem;">
            <i class="bi bi-info-circle me-1"></i>
            Replacing will swap the display order between both items.
        </p>

    </div>
</div>

@section Scripts {
    <script>
        // ── Taken orders data from server ─────────────────────
        var takenOrders    = @Html.Raw(ViewBag.TakenOrdersJson ?? "[]");
        var currentOrder   = @Model.DisplayOrder;
        var selectedOrder  = currentOrder;
        var maxSize        = 3 * 1024 * 1024;
        var allowedExts    = new RegExp('\\.(jpg|jpeg|png|gif)$', 'i');

        // ── On display order change ───────────────────────────
        document.getElementById('displayOrderSelect')
            .addEventListener('change', function () {
            selectedOrder = parseInt(this.value);
            document.getElementById('orderError').textContent = '';
        });

        // ── Image preview ─────────────────────────────────────
        function previewImage(input) {
            var file  = input.files[0];
            var box   = document.getElementById('imagePreviewBox');
            var errEl = document.getElementById('imageFileError');
            errEl.textContent = '';

            if (!file) return;

            if (!allowedExts.test(file.name)) {
                errEl.textContent = 'Only JPG, PNG, and GIF files are allowed.';
                input.value = '';
                return;
            }
            if (file.size > maxSize) {
                errEl.textContent = 'File size must not exceed 3 MB.';
                input.value = '';
                return;
            }

            var reader = new FileReader();
            reader.onload = function (e) {
                box.innerHTML =
                    '<img src="' + e.target.result + '" ' +
                    'style="width:100%;height:100%;' +
                    'object-fit:cover;border-radius:8px;" />';
            };
            reader.readAsDataURL(file);
        }

        // ── Form submit handler ───────────────────────────────
        document.getElementById('workEditForm')
            .addEventListener('submit', function (e) {
            var valid = true;

            // Validate display order selected
            var orderVal = document.querySelector(
                'select[name="DisplayOrder"]').value;

            if (!orderVal) {
                document.getElementById('orderError').textContent =
                    'Please select a display order.';
                valid = false;
                e.preventDefault();
                return;
            }

            var chosenOrder = parseInt(orderVal);

            // ── Check if chosen order is taken by another item ─
            var conflict = null;
            for (var i = 0; i < takenOrders.length; i++) {
                if (takenOrders[i].order === chosenOrder) {
                    conflict = takenOrders[i];
                    break;
                }
            }

            if (conflict) {
                e.preventDefault();
                // ── Show popup with conflict info ─────────────
                document.getElementById('popupMessage').innerHTML =
                    'Display order <strong>' + chosenOrder +
                    '</strong> is currently assigned to:<br>' +
                    '<strong>"' + conflict.title + '"</strong><br><br>' +
                    'Do you want to replace it? Their order will be ' +
                    'swapped to your current order ' +
                    '<strong>' + currentOrder + '</strong>.';

                var overlay = document.getElementById('replacePopupOverlay');
                overlay.style.display = 'flex';
            } else {
                // No conflict — set replaceOrder false and submit
                document.getElementById('replaceOrderInput').value = 'false';
            }
        });

        // ── User clicks Replace & Swap ────────────────────────
        function confirmReplace() {
            document.getElementById('replaceOrderInput').value = 'true';
            document.getElementById('replacePopupOverlay').style.display = 'none';
            document.getElementById('workEditForm').submit();
        }

        // ── User clicks Back — revert to current order ────────
        function cancelReplace() {
            document.getElementById('replacePopupOverlay').style.display = 'none';

            // Reset dropdown to current order
            var select = document.getElementById('displayOrderSelect');
            for (var i = 0; i < select.options.length; i++) {
                if (parseInt(select.options[i].value) === currentOrder) {
                    select.selectedIndex = i;
                    break;
                }
            }

            selectedOrder = currentOrder;
        }
    </script>
}


