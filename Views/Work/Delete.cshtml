@model PopZebra.Models.WorkItem
@{
    ViewData["Title"] = "Work - Delete";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body">

                <div class="alert alert-warning d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-circle-fill mt-1"></i>
                    <div>
                        Are you sure you want to delete this work item?
                        <strong>This action cannot be undone.</strong>
                        The uploaded image will also be permanently deleted and
                        display order slot <strong>@Model.DisplayOrder</strong>
                        will become available again.
                    </div>
                </div>

                <div class="text-center mb-4">
                    <img src="@Model.ImagePath"
                         style="max-height:160px;object-fit:cover;
                                border-radius:10px;border:1px solid #eee;"
                         alt="@Model.Title" />
                </div>

                <table class="table table-bordered table-sm mb-4">
                    <tr>
                        <th class="table-light" style="width:38%">ID</th>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <th class="table-light">Title</th>
                        <td>@Model.Title</td>
                    </tr>
                    <tr>
                        <th class="table-light">Link URL</th>
                        <td style="word-break:break-all;">@Model.LinkUrl</td>
                    </tr>
                    <tr>
                        <th class="table-light">Display Order</th>
                        <td>@Model.DisplayOrder</td>
                    </tr>
                    <tr>
                        <th class="table-light">Created On</th>
                        <td>@Model.CreatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <th class="table-light">Updated On</th>
                        <td>@Model.UpdatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>

                <form method="post"
                      asp-action="Delete"
                      asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
