@model PopZebra.Models.WorkItemViewModel
@{
    ViewData["Title"] = "Work - Create";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle me-2"></i>Create Work Item
                <small class="text-muted ms-2">
                    (@Model.AvailableOrders.Count slot@(Model.AvailableOrders.Count == 1 ? "" : "s") remaining)
                </small>
            </div>
            <div class="card-body">

                <form method="post"
                      asp-action="Create"
                      enctype="multipart/form-data"
                      id="workCreateForm"
                      novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Enter work item title" />
                        <span asp-validation-for="Title"
                              class="text-danger small"></span>
                    </div>

                    <!-- Link URL -->
                    <div class="mb-4">
                        <label asp-for="LinkUrl" class="form-label">
                            Link URL <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-link-45deg"></i>
                            </span>
                            <input asp-for="LinkUrl"
                                   class="form-control"
                                   placeholder="https://..." />
                        </div>
                        <span asp-validation-for="LinkUrl"
                              class="text-danger small"></span>
                    </div>

                    <!-- Display Order -->
                    <div class="mb-4">
                        <label asp-for="DisplayOrder" class="form-label">
                            Display Order <span class="text-danger">*</span>
                        </label>
                        <select asp-for="DisplayOrder" class="form-select">
                            <option value="">-- Select display order --</option>
                            @foreach (var order in Model.AvailableOrders)
                            {
                                <option value="@order">@order</option>
                            }
                        </select>
                        <span asp-validation-for="DisplayOrder"
                              class="text-danger small"></span>
                        <div class="form-text">
                            Only available slots are shown.
                            Used slots:
                            @{
                                var usedSlots = Enumerable.Range(1, 5)
                                .Where(n => !Model.AvailableOrders.Contains(n))
                                .ToList();
                            }
                            @(usedSlots.Any()
                                                        ? string.Join(", ", usedSlots)
                                                        : "None")
                        </div>
                        <div id="orderError" class="text-danger small mt-1"></div>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-4">
                        <label class="form-label">
                            Image <span class="text-danger">*</span>
                        </label>
                        <div class="img-preview-box"
                             id="imagePreviewBox"
                             onclick="document.getElementById('imageFileInput').click()">
                            <div class="placeholder-text">
                                <i class="bi bi-cloud-upload fs-3 d-block mb-2 text-muted"></i>
                                Click to upload image<br />
                                <small>JPG, PNG, GIF — max 3MB</small>
                            </div>
                        </div>
                        <input type="file"
                               id="imageFileInput"
                               name="ImageFile"
                               accept=".jpg,.jpeg,.png,.gif"
                               class="d-none"
                               onchange="previewImage(this)" />
                        <span asp-validation-for="ImageFile"
                              class="text-danger small"></span>
                        <div id="imageFileError" class="text-danger small mt-1"></div>
                    </div>

                    <!-- Submit -->
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Save
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var maxSize     = 3 * 1024 * 1024;
        var allowedExts = new RegExp('\\.(jpg|jpeg|png|gif)$', 'i');

        function previewImage(input) {
            var file  = input.files[0];
            var box   = document.getElementById('imagePreviewBox');
            var errEl = document.getElementById('imageFileError');
            errEl.textContent = '';

            if (!file) return;

            if (!allowedExts.test(file.name)) {
                errEl.textContent = 'Only JPG, PNG, and GIF files are allowed.';
                input.value = '';
                return;
            }
            if (file.size > maxSize) {
                errEl.textContent = 'File size must not exceed 3 MB.';
                input.value = '';
                return;
            }

            var reader = new FileReader();
            reader.onload = function (e) {
                box.innerHTML =
                    '<img src="' + e.target.result + '" ' +
                    'style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />';
            };
            reader.readAsDataURL(file);
        }

        document.getElementById('workCreateForm').addEventListener('submit', function (e) {
            var valid = true;

            var title = document.querySelector('input[name="Title"]').value.trim();
            if (!title) valid = false;

            var link = document.querySelector('input[name="LinkUrl"]').value.trim();
            if (!link) valid = false;

            var order = document.querySelector('select[name="DisplayOrder"]').value;
            if (!order) {
                document.getElementById('orderError').textContent =
                    'Please select a display order.';
                valid = false;
            } else {
                document.getElementById('orderError').textContent = '';
            }

            var fileInput = document.getElementById('imageFileInput');
            if (!fileInput.files || fileInput.files.length === 0) {
                document.getElementById('imageFileError').textContent =
                    'Please upload an image.';
                valid = false;
            } else {
                document.getElementById('imageFileError').textContent = '';
            }

            if (!valid) e.preventDefault();
        });
    </script>
}