@model PopZebra.Models.PaginatedList<PopZebra.Models.HomeSection>
@{
    ViewData["Title"] = "Home Module";
    Layout = "_Layout";
    int serialStart = ((Model.PageIndex - 1) * Model.PageSize) + 1;
    int sno = serialStart;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1 pz-section-title">Home Sections</h5>
       
    </div>
    <a asp-action="Create" class="btn btn-primary px-4">
        <i class="bi bi-plus-lg me-1"></i>Add New
    </a>
</div>

@if (!Model.Items.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-house display-4 text-muted mb-3 d-block"></i>
            <h6 class="text-muted">No home sections found</h6>
            <a asp-action="Create" class="btn btn-primary mt-2">
                Add First Section
            </a>
        </div>
    </div>
}
else
{
    <p class="text-muted small ">
        Total Record@(Model.TotalCount == 1 ? "" : "s") : <span class="ms-2"> @Model.TotalCount</span>
    </p>
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">S.No</th>
                            <th>Title</th>
                            <th>Link URL</th>
                            <th style="display:none;">Image Mode</th>
                            <th style="display:none;">Preview</th>
                            <th>Created On</th>
                            <th>Updated On</th>
                            <th style="width:160px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-muted small align-middle fw-semibold">
                                    @sno
                                </td>
                                <td class="fw-semibold align-middle">
                                    @item.Title
                                </td>
                                <td class="align-middle" >
                                    @if (!string.IsNullOrEmpty(item.LinkUrl))
                                    {
                                        <a href="@item.LinkUrl"
                                           target="_blank"
                                           class="text-decoration-none small"
                                           style="color:var(--brand-accent);">
                                            <i class="bi bi-link-45deg"></i>
                                            @(item.LinkUrl.Length > 30
                                                                            ? item.LinkUrl[..30] + "..."
                                                                            : item.LinkUrl)
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="align-middle" style="display:none">
                                    @if (item.SetImageFor)
                                    {
                                        <span class="badge-active px-2 py-1">
                                            <i class="bi bi-check-circle me-1"></i>Single
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive px-2 py-1">
                                            <i class="bi bi-tablet-landscape me-1"></i>
                                            Mobile + Desktop
                                        </span>
                                    }
                                </td>
                                <td class="align-middle" style="display:none">
                                    @if (item.SetImageFor && item.SingleImagePath != null)
                                    {
                                        <img src="@item.SingleImagePath"
                                             class="table-img" alt="Single" />
                                    }
                                    else if (!item.SetImageFor)
                                    {
                                        <div class="d-flex gap-1">
                                            @if (item.MobileImagePath != null)
                                            {
                                                <img src="@item.MobileImagePath"
                                                     class="table-img"
                                                     alt="Mobile" title="Mobile" />
                                            }
                                            @if (item.DesktopImagePath != null)
                                            {
                                                <img src="@item.DesktopImagePath"
                                                     class="table-img"
                                                     alt="Desktop" title="Desktop" />
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-muted small align-middle">
                                    @item.CreatedOn.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-muted small align-middle">
                                    @item.UpdatedOn.ToString("dd MMM yyyy")
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary"
                                           title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            sno++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", new PopZebra.Models.PaginationViewModel
    {
        PageIndex = Model.PageIndex,
        TotalPages = Model.TotalPages,
        TotalCount = Model.TotalCount,
        PageSize = Model.PageSize,
        Url = p => Url.Action("Index", "HomeModule", new { page = p })!
    })
}