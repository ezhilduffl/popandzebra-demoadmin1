@model PopZebra.Models.HomeSection
@{
    ViewData["Title"] = "Home - Delete";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body">

                <div class="alert alert-warning d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-circle-fill mt-1"></i>
                    <div>
                        Are you sure you want to delete this home section?
                        <strong>This action cannot be undone.</strong>
                        All uploaded images will also be permanently deleted.
                    </div>
                </div>

                <table class="table table-bordered table-sm mb-4">
                    <tr>
                        <th class="table-light" style="width:35%">ID</th>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <th class="table-light">Title</th>
                        <td>@Model.Title</td>
                    </tr>
                    <tr>
                        <th class="table-light">Image Mode</th>
                        <td>
                            @(Model.SetImageFor ? "Single Image" : "Mobile + Desktop")
                        </td>
                    </tr>
                    <tr>
                        <th class="table-light">Created On</th>
                        <td>@Model.CreatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <th class="table-light">Updated On</th>
                        <td>@Model.UpdatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>

                @if (Model.SetImageFor && Model.SingleImagePath != null)
                {
                    <div class="mb-3">
                        <label class="form-label text-muted small">Image to be deleted</label>
                        <img src="@Model.SingleImagePath"
                             style="height:120px;object-fit:cover;border-radius:8px;display:block;"
                             alt="Image" />
                    </div>
                }
                @if (!Model.SetImageFor)
                {
                    <div class="d-flex gap-3 mb-3">
                        @if (Model.MobileImagePath != null)
                        {
                            <div>
                                <small class="text-muted d-block mb-1">Mobile</small>
                                <img src="@Model.MobileImagePath"
                                     style="height:100px;object-fit:cover;border-radius:8px;"
                                     alt="Mobile" />
                            </div>
                        }
                        @if (Model.DesktopImagePath != null)
                        {
                            <div>
                                <small class="text-muted d-block mb-1">Desktop</small>
                                <img src="@Model.DesktopImagePath"
                                     style="height:100px;object-fit:cover;border-radius:8px;"
                                     alt="Desktop" />
                            </div>
                        }
                    </div>
                }

                <form method="post"
                      asp-action="Delete"
                      asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

