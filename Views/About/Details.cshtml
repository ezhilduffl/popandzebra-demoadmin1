@model PopZebra.Models.AboutSection
@{
    ViewData["Title"] = "About - Details";
    Layout = "_Layout";
}
<div class="d-flex justify-content-between align-items-center">
<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>
<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-sm btn-primary">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a asp-action="Delete" asp-route-id="@Model.Id"
           class="btn btn-sm btn-outline-danger">
        <i class="bi bi-trash me-1"></i>Delete
    </a>
</div>
</div>
<div class="row justify-content-center">
    <div class="col-xl-12 col-lg-9">
        <div class="row">
        <div class="col-xl-6">

        <!-- Content Card -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-info-circle me-2"></i>About Section Details</span>
             
            </div>
            <div class="card-body">

                <div class="row mb-3 d-none">
                    <div class="col-sm-3 text-muted fw-semibold">ID</div>
                    <div class="col-sm-9">@Model.Id</div>
                </div>
                

                <div class="row mb-3">
                    <div class="col-sm-12 mb-2 text-muted fw-semibold">Content</div>
                    <div class="col-sm-12">
                        <div class="p-3 bg-light rounded"
                             style="font-size:.9rem;line-height:1.7;">
                            @Html.Raw(Model.Content)
                        </div>
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-semibold">Status</div>
                    <div class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge-active px-2 py-1">
                                <i class="bi bi-check-circle me-1"></i>Active
                            </span>
                        }
                        else
                        {
                            <span class="badge-inactive px-2 py-1">
                                <i class="bi bi-x-circle me-1"></i>Inactive
                            </span>
                        }
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-semibold">Created On</div>
                    <div class="col-sm-9">
                        @Model.CreatedOn.ToString("dd MMM yyyy")
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-1">
                    <div class="col-sm-3 text-muted fw-semibold">Updated On</div>
                    <div class="col-sm-9">
                        @Model.UpdatedOn.ToString("dd MMM yyyy")
                    </div>
                </div>

            </div>
        </div>
        </div>
        <div class="col-xl-6">
        <!-- Icons Card -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-grid me-2"></i>Icon Section
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var icon in Model.Icons.OrderBy(i => i.SortOrder))
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="border rounded-3 p-3 text-center h-100"
                                 style="background:#f8f9fe;">
                                <div class="mb-2">
                                    <span class="badge rounded-pill text-white mb-2"
                                          style="background:var(--brand-accent);
                                                     font-size:.72rem;">
                                        Icon @icon.SortOrder
                                    </span>
                                </div>
                                <img src="@icon.IconPath"
                                     style="width:56px;height:56px;
                                                object-fit:contain;border-radius:10px;
                                                border:1px solid #eee;background:#fff;
                                                padding:4px;"
                                     alt="@icon.Title" />
                                <div class="fw-semibold mt-2 small">@icon.Title</div>
                                <div class="mt-1">
                                    <a href="@icon.LinkUrl"
                                       target="_blank"
                                       class="text-decoration-none small"
                                       style="color:var(--brand-accent);
                                                  word-break:break-all;">
                                        <i class="bi bi-link-45deg"></i>
                                        @(icon.LinkUrl.Length > 30
                                                                            ? icon.LinkUrl[..30] + "..."
                                                                            : icon.LinkUrl)
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        </div>
        </div>
    </div>
</div>