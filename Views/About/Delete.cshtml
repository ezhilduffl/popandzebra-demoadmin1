@model PopZebra.Models.AboutSection
@{
    ViewData["Title"] = "About - Delete";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body">

                <div class="alert alert-warning d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-circle-fill mt-1"></i>
                    <div>
                        Are you sure you want to delete this about section?
                        <strong>This action cannot be undone.</strong>
                        All 5 icon images will also be permanently deleted.
                    </div>
                </div>

                <table class="table table-bordered table-sm mb-4">
                    <tr>
                        <th class="table-light" style="width:35%">ID</th>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <th class="table-light">Content Preview</th>
                        <td>
                            <small>
                                @(Model.Content.Length > 120
                                                                ? Model.Content[..120] + "..."
                                                                : Model.Content)
                            </small>
                        </td>
                    </tr>
                    <tr>
                        <th class="table-light">Status</th>
                        <td>@(Model.IsActive ? "Active" : "Inactive")</td>
                    </tr>
                    <tr>
                        <th class="table-light">Icons</th>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var icon in Model.Icons
                                                                .OrderBy(i => i.SortOrder))
                                {
                                    <img src="@icon.IconPath"
                                         style="width:36px;height:36px;
                                                    object-fit:contain;border-radius:6px;
                                                    border:1px solid #eee;background:#fff;
                                                    padding:2px;"
                                         title="@icon.Title"
                                         alt="@icon.Title" />
                                }
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <th class="table-light">Created On</th>
                        <td>@Model.CreatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <th class="table-light">Updated On</th>
                        <td>@Model.UpdatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>

                <form method="post"
                      asp-action="Delete"
                      asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>