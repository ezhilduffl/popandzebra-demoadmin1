@model PopZebra.Models.ShopItemViewModel
@{
    ViewData["Title"] = "Shop - Edit";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">

        <!-- Edit notice -->
        <div class="alert d-flex align-items-start gap-2 mb-4"
             style="background:#fffbeb;border:1px solid #fde68a;color:#92400e;">
            <i class="bi bi-clock-history mt-1 flex-shrink-0"></i>
            <div>
                <strong>Version tracking is active.</strong>
                When you save, the current version will be automatically
                archived to history before updating.
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>Edit Shop Item
            </div>
            <div class="card-body">

                <form method="post"
                      asp-action="Edit"
                      asp-route-id="@Model.Id"
                      enctype="multipart/form-data"
                      id="shopEditForm"
                      novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Content -->
                    <div class="mb-4">
                        <label asp-for="Content" class="form-label">
                            Content <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="6"
                                  placeholder="Enter shop item content..."></textarea>
                        <span asp-validation-for="Content"
                              class="text-danger small"></span>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-4">
                        <label class="form-label">
                            Image
                            <small class="text-muted fw-normal">
                                (Upload new to replace — old image kept in history)
                            </small>
                        </label>
                        @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                        {
                            <div class="mb-2">
                                <img src="@Model.ExistingImagePath"
                                     style="height:130px;object-fit:cover;
                                                border-radius:8px;display:block;"
                                     alt="Current image" />
                                <small class="text-muted">Current image</small>
                            </div>
                        }
                        <div class="img-preview-box"
                             id="imagePreviewBox"
                             onclick="document.getElementById('imageFileInput').click()">
                            <div class="placeholder-text">
                                <i class="bi bi-cloud-upload fs-3 d-block mb-2 text-muted"></i>
                                Click to upload new image<br />
                                <small>JPG, PNG, GIF — max 3MB</small>
                            </div>
                        </div>
                        <input type="file"
                               id="imageFileInput"
                               name="ImageFile"
                               accept=".jpg,.jpeg,.png,.gif"
                               class="d-none"
                               onchange="previewImage(this)" />
                        <div id="imageFileError" class="text-danger small mt-1"></div>
                    </div>

                    <!-- Timestamps -->
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="form-label text-muted small">Created On</label>
                            <input type="text"
                                   class="form-control form-control-sm bg-light"
                                   value="@Model.CreatedOn?.ToString("dd MMM yyyy")"
                                   readonly />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label text-muted small">Last Updated</label>
                            <input type="text"
                                   class="form-control form-control-sm bg-light"
                                   value="@Model.UpdatedOn?.ToString("dd MMM yyyy")"
                                   readonly />
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Update
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var maxSize     = 3 * 1024 * 1024;
        var allowedExts = new RegExp('\\.(jpg|jpeg|png|gif)$', 'i');

        function previewImage(input) {
            var file  = input.files[0];
            var box   = document.getElementById('imagePreviewBox');
            var errEl = document.getElementById('imageFileError');
            errEl.textContent = '';

            if (!file) return;

            if (!allowedExts.test(file.name)) {
                errEl.textContent = 'Only JPG, PNG, and GIF files are allowed.';
                input.value = '';
                return;
            }
            if (file.size > maxSize) {
                errEl.textContent = 'File size must not exceed 3 MB.';
                input.value = '';
                return;
            }

            var reader = new FileReader();
            reader.onload = function (e) {
                box.innerHTML =
                    '<img src="' + e.target.result + '" ' +
                    'style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />';
            };
            reader.readAsDataURL(file);
        }
    </script>
}