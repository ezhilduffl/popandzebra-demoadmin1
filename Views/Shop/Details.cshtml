@model PopZebra.Models.ShopItem
@{
    ViewData["Title"] = "Shop - Details";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- Current version card -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-bag me-2"></i>Current Version
                    <span class="badge ms-2"
                          style="background:#dcfce7;color:#166534;font-size:.72rem;">
                        Live
                    </span>
                </span>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            </div>
            <div class="card-body">

                <div class="row mb-3 d-none">
                    <div class="col-sm-3 text-muted fw-semibold">ID</div>
                    <div class="col-sm-9">@Model.Id</div>
                </div>
                @* <hr class="my-2" /> *@

                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-semibold">Content</div>
                    <div class="col-sm-9">
                        <div class="p-3 bg-light rounded"
                             style="font-size:.9rem;line-height:1.7;">
                            @Model.Content
                        </div>
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-semibold">Image</div>
                    <div class="col-sm-9">
                        <img src="@Model.ImagePath"
                             class="img-fluid rounded"
                             style="max-height:220px;object-fit:cover;"
                             alt="Shop item" />
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-3">
                    <div class="col-sm-3 text-muted fw-semibold">Created On</div>
                    <div class="col-sm-9">
                        @Model.CreatedOn.ToString("dd MMM yyyy")
                    </div>
                </div>
                <hr class="my-2" />

                <div class="row mb-1">
                    <div class="col-sm-3 text-muted fw-semibold">Updated On</div>
                    <div class="col-sm-9">
                        @Model.UpdatedOn.ToString("dd MMM yyyy")
                    </div>
                </div>

            </div>
        </div>

        <!-- History card -->
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-clock-history"></i>
                Edit History
                <span class="badge rounded-pill ms-1"
                      style="background:#f0f9ff;color:#0369a1;
                             border:1px solid #bae6fd;font-size:.72rem;">
                    @Model.History.Count version@(Model.History.Count == 1 ? "" : "s")
                </span>
            </div>
            <div class="card-body">

                @if (!Model.History.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-clock-history display-6 text-muted d-block mb-2"></i>
                        <p class="text-muted small mb-0">
                            No history yet. History is created when this item is edited.
                        </p>
                    </div>
                }
                else
                {
                    <div class="timeline">
                        @foreach (var (h, idx) in Model.History
                                            .Select((h, i) => (h, i)))
                        {
                            <div class="border rounded-3 p-3 mb-3"
                                 style="background:#fafafa;position:relative;">

                                <div class="d-flex justify-content-between
                                                    align-items-start mb-2">
                                    <span class="badge"
                                          style="background:#f0f9ff;color:#0369a1;
                                                         font-size:.72rem;">
                                        Version @(Model.History.Count - idx)
                                    </span>
                                    <small class="text-muted">
                                        <i class="bi bi-clock me-1"></i>
                                        @h.SavedOn.ToString("dd MMM yyyy")
                                    </small>
                                </div>

                                <div class="row g-3 align-items-start">
                                    <div class="col-md-3">
                                        <img src="@h.ImagePath"
                                             style="width:100%;max-height:120px;
                                                            object-fit:cover;border-radius:8px;
                                                            border:1px solid #e5e7eb;"
                                             alt="Version @(Model.History.Count - idx)" />
                                    </div>
                                    <div class="col-md-9">
                                        <p class="mb-0 small"
                                           style="line-height:1.7;color:#374151;">
                                            @(h.Content.Length > 200
                                                                                ? h.Content[..200] + "..."
                                                                                : h.Content)
                                        </p>
                                    </div>
                                </div>

                            </div>
                        }
                    </div>
                }

            </div>
        </div>

    </div>
</div>