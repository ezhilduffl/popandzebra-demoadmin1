@model PopZebra.Models.ShopItem
@{
    ViewData["Title"] = "Shop - Delete";
    Layout = "_Layout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body">

                <div class="alert alert-warning d-flex align-items-start gap-2">
                    <i class="bi bi-exclamation-circle-fill mt-1 flex-shrink-0"></i>
                    <div>
                        Are you sure you want to delete this shop item?
                        <strong>This action cannot be undone.</strong>
                        The current image, all
                        <strong>@Model.History.Count</strong>
                        history version@(Model.History.Count == 1 ? "" : "s")
                        and their images will also be permanently deleted.
                    </div>
                </div>

                <div class="text-center mb-4">
                    <img src="@Model.ImagePath"
                         style="max-height:150px;object-fit:cover;
                                border-radius:10px;border:1px solid #eee;"
                         alt="Shop item" />
                </div>

                <table class="table table-bordered table-sm mb-4">
                    <tr>
                        <th class="table-light" style="width:38%">ID</th>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <th class="table-light">Content Preview</th>
                        <td>
                            <small>
                                @(Model.Content.Length > 100
                                                                ? Model.Content[..100] + "..."
                                                                : Model.Content)
                            </small>
                        </td>
                    </tr>
                    <tr>
                        <th class="table-light">History Versions</th>
                        <td>@Model.History.Count</td>
                    </tr>
                    <tr>
                        <th class="table-light">Created On</th>
                        <td>@Model.CreatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <th class="table-light">Updated On</th>
                        <td>@Model.UpdatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>

                <form method="post"
                      asp-action="Delete"
                      asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Yes, Delete All
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
